# Copy this file to .env and fill in your own keys. Never commit .env.

# Primary LLM (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Fallback LLM (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Judges + final graded eval run (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Embeddings: true = local sentence-transformers (offline, no quota) — the default we run with.
# false = Gemini 768-d embeddings (uses API quota on every chunk + query).
USE_LOCAL_EMBEDDER=true

# Vector store location (git-ignored)
CHROMA_PATH=./chroma_db

# Date the corpus snapshot was taken — drives the temporal agent's "as of" notices.
# Keep in sync with SNAPSHOT_DATE in ingestion/corpus_manifest.py.
CORPUS_SNAPSHOT_DATE=2026-07-01

# Retrieval + orchestration tuning
TOP_K=6
MAX_AGENT_RETRIES=2
