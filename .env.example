# Copy this file to .env and fill in your own keys. Never commit .env.

# Which vendor answers generation calls: ollama | gemini | anthropic.
# ollama = local, free, quota-less — the development/eval default.
# The OpenRouter fallback wraps whichever vendor is chosen.
LLM_VENDOR=ollama

# Ollama (https://ollama.com). Default is a cloud model — needs `ollama
# signin` but no local pull/GPU. For a fully offline local model instead,
# `ollama pull qwen2.5:7b-instruct` and set OLLAMA_MODEL to that tag.
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_HOST=http://localhost:11434

# Gemini — backup vendor (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Fallback LLM (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Judges + final graded eval run (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Embeddings: true = local sentence-transformers (offline, no quota) — the default we run with.
# false = Gemini 768-d embeddings (uses API quota on every chunk + query).
USE_LOCAL_EMBEDDER=true

# Vector store location (git-ignored)
CHROMA_PATH=./chroma_db

# Date the corpus snapshot was taken — drives the temporal agent's "as of" notices.
# Keep in sync with SNAPSHOT_DATE in ingestion/corpus_manifest.py.
CORPUS_SNAPSHOT_DATE=2026-07-01

# Retrieval + orchestration tuning
TOP_K=6
MAX_AGENT_RETRIES=2
